# Frontend env. Copy to `.env`.

# Same Google OAuth Client ID as the server. Leave empty to use dev-login only.
VITE_GOOGLE_CLIENT_ID=

# API base. Empty -> uses the Vite dev proxy (/api -> :4000).
VITE_API_BASE=

# Show the dev-login panel (sign in as seeded users without Google). Dev only.
VITE_ALLOW_DEV_LOGIN=true
