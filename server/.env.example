# ANINA Booking API — environment
# Copy to `.env` and fill in. `.env` is gitignored.

PORT=4000
MONGO_DB_NAME=ANINA
XENDIT_SIMULATION=true

# Local MongoDB (Homebrew service). Swap to a hosted URI (e.g. Atlas) to go live.
MONGO_URI=mongodb://127.0.0.1:27017/anina

# Secret for signing our own session JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth — create a Web-application OAuth Client ID at
# https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 as an authorized JavaScript origin.
# The SAME id goes in the frontend (app/.env as VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Comma-separated emails that become ANINA Admin automatically on first login.
ADMIN_EMAILS=patrick.ong.wong@gmail.com

# Where the frontend runs (for CORS).
CLIENT_ORIGIN=http://localhost:5173

# App URL used for Xendit success/cancel return links.
APP_BASE_URL=http://localhost:5173

# --- Xendit subscriptions ---
# Leave XENDIT_SECRET_KEY empty to run billing in SIMULATION mode (no external
# calls; clients "complete" payment via the in-app dev button). Set a
# development key (xnd_development_...) to hit the real Xendit sandbox.
XENDIT_SECRET_KEY=
XENDIT_API_BASE=https://api.xendit.co
# Shared secret to verify incoming webhooks (set the same value in Xendit).
XENDIT_WEBHOOK_TOKEN=
